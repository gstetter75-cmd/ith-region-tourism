---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Seite nicht gefunden" description="Die angeforderte Seite wurde nicht gefunden.">
  <section class="min-h-[70vh] flex items-center justify-center bg-sand">
    <div class="text-center px-4">
      <span class="text-8xl font-extrabold text-ith-blue/20">404</span>
      <h1 class="text-3xl font-extrabold mt-4 mb-4">Seite nicht gefunden</h1>
      <p class="text-anthracite-light text-lg mb-8 max-w-md mx-auto">
        Der Weg, den du suchst, existiert leider nicht.
        Aber in der Ith-Region gibt es viele andere Wege zu entdecken!
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="btn-primary">Zurück zur Startseite</a>
        <a href="/entdecken/karte/" class="btn-secondary">Karte ansehen</a>
      </div>
    </div>
  </section>
</BaseLayout>
