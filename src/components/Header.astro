---
const currentPath = Astro.url.pathname;

const navItems = [
  { label: "Startseite", href: "/" },
  {
    label: "Erleben",
    href: "/erleben/",
    children: [
      { label: "Wandern", href: "/erleben/wandern/" },
      { label: "Radfahren", href: "/erleben/radfahren/" },
      { label: "Klettern", href: "/erleben/klettern/" },
      { label: "Natur & Foto-Spots", href: "/erleben/natur/" },
      { label: "Kultur & Geschichte", href: "/erleben/kultur/" },
      { label: "Familien", href: "/erleben/familien/" },
    ],
  },
  {
    label: "Entdecken",
    href: "/entdecken/",
    children: [
      { label: "Salzhemmendorf", href: "/entdecken/salzhemmendorf/" },
      { label: "Coppenbrügge", href: "/entdecken/coppenbruegge/" },
      { label: "Interaktive Karte", href: "/entdecken/karte/" },
    ],
  },
  {
    label: "Planen",
    href: "/planen/",
    children: [
      { label: "Unterkünfte", href: "/planen/unterkuenfte/" },
      { label: "Gastronomie", href: "/planen/gastronomie/" },
      { label: "Anreise & Parken", href: "/planen/anreise/" },
      { label: "Barrierefrei", href: "/planen/barrierefrei/" },
    ],
  },
  { label: "Veranstaltungen", href: "/veranstaltungen/" },
  { label: "Regional", href: "/regional/" },
];

function isActive(href: string): boolean {
  if (href === "/") return currentPath === "/";
  return currentPath.startsWith(href);
}
---

<header
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
  id="main-header"
>
  <div class="container mx-auto px-4 lg:px-6">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 no-underline shrink-0">
        <img
          src="/images/logo-ith-region.svg"
          alt="Ith-Region Logo"
          class="h-12 w-auto"
        />
        <div class="hidden sm:block">
          <span class="block text-lg font-bold text-ith-blue-dark leading-tight"
            >Ith-Region</span
          >
          <span class="block text-xs text-anthracite-light"
            >Jeder Weg ist dein Erlebnis</span
          >
        </div>
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden lg:flex items-center gap-1" aria-label="Hauptnavigation">
        {
          navItems.map((item) => (
            <div class="relative group">
              <a
                href={item.href}
                class:list={[
                  "px-3 py-2 text-sm font-medium rounded-lg no-underline transition-colors",
                  isActive(item.href)
                    ? "text-ith-blue bg-ith-blue-light"
                    : "text-anthracite hover:text-ith-blue hover:bg-ith-blue-light/50",
                ]}
              >
                {item.label}
                {item.children && (
                  <svg
                    class="inline-block w-3 h-3 ml-1"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M19 9l-7 7-7-7"
                    />
                  </svg>
                )}
              </a>
              {item.children && (
                <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible group-focus-within:opacity-100 group-focus-within:visible transition-all duration-200">
                  <div class="bg-white rounded-xl shadow-lg border border-gray-100 py-2 min-w-[200px]">
                    {item.children.map((child) => (
                      <a
                        href={child.href}
                        class:list={[
                          "block px-4 py-2 text-sm no-underline transition-colors",
                          isActive(child.href)
                            ? "text-ith-blue bg-ith-blue-light"
                            : "text-anthracite hover:text-ith-blue hover:bg-ith-blue-light/50",
                        ]}
                      >
                        {child.label}
                      </a>
                    ))}
                  </div>
                </div>
              )}
            </div>
          ))
        }
      </nav>

      <!-- Mobile Menu Button -->
      <button
        class="lg:hidden p-2 rounded-lg hover:bg-gray-100 transition-colors"
        id="mobile-menu-btn"
        aria-label="Menü öffnen"
        aria-expanded="false"
      >
        <svg
          class="w-6 h-6 text-anthracite"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          id="menu-icon"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
        <svg
          class="w-6 h-6 text-anthracite hidden"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          id="close-icon"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div class="lg:hidden hidden bg-white border-t border-gray-100 shadow-lg" id="mobile-menu">
    <nav class="container mx-auto px-4 py-4 space-y-1" aria-label="Mobile Navigation">
      {
        navItems.map((item) => (
          <>
            <a
              href={item.href}
              class:list={[
                "block px-4 py-3 rounded-lg text-sm font-medium no-underline transition-colors",
                isActive(item.href)
                  ? "text-ith-blue bg-ith-blue-light"
                  : "text-anthracite hover:text-ith-blue hover:bg-ith-blue-light/50",
              ]}
            >
              {item.label}
            </a>
            {item.children?.map((child) => (
              <a
                href={child.href}
                class:list={[
                  "block px-8 py-2 rounded-lg text-sm no-underline transition-colors",
                  isActive(child.href)
                    ? "text-ith-blue bg-ith-blue-light"
                    : "text-anthracite-light hover:text-ith-blue hover:bg-ith-blue-light/50",
                ]}
              >
                {child.label}
              </a>
            ))}
          </>
        ))
      }
    </nav>
  </div>
</header>

<script>
  const header = document.getElementById("main-header");
  const mobileMenuBtn = document.getElementById("mobile-menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");
  const menuIcon = document.getElementById("menu-icon");
  const closeIcon = document.getElementById("close-icon");

  // Scroll-based header styling
  function updateHeader() {
    if (!header) return;
    if (window.scrollY > 50) {
      header.classList.add("bg-white/95", "backdrop-blur-md", "shadow-sm");
    } else {
      header.classList.remove("bg-white/95", "backdrop-blur-md", "shadow-sm");
      header.classList.add("bg-white");
    }
  }

  window.addEventListener("scroll", updateHeader, { passive: true });
  updateHeader();

  // Mobile menu toggle
  mobileMenuBtn?.addEventListener("click", () => {
    const isOpen = mobileMenu?.classList.contains("hidden") === false;
    mobileMenu?.classList.toggle("hidden");
    menuIcon?.classList.toggle("hidden");
    closeIcon?.classList.toggle("hidden");
    mobileMenuBtn.setAttribute("aria-expanded", String(!isOpen));
  });
</script>
