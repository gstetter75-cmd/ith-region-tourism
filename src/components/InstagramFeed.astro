---
/**
 * Instagram Feed Component
 *
 * Shows a link to Instagram with placeholder grid.
 * Can be replaced with real Instagram embed once the account
 * @ithregion has enough posts and an API token is available.
 *
 * For real integration later, use the Instagram Basic Display API
 * or a service like Behold (behold.so) or EmbedSocial.
 */

interface Props {
  username?: string;
  title?: string;
}

const { username = "ithregion", title = "Folge uns auf Instagram" } = Astro.props;

const placeholderImages = [
  { src: "https://images.unsplash.com/photo-1551632811-561732d1e306?w=300&h=300&fit=crop", alt: "Wanderweg" },
  { src: "https://images.unsplash.com/photo-1470071459604-3b5ec3a7fe05?w=300&h=300&fit=crop", alt: "Hügellandschaft" },
  { src: "https://images.unsplash.com/photo-1522163182402-834f871fd851?w=300&h=300&fit=crop", alt: "Klettern" },
  { src: "https://images.unsplash.com/photo-1441974231531-c6227db76b6e?w=300&h=300&fit=crop", alt: "Wald" },
  { src: "https://images.unsplash.com/photo-1500382017468-9049fed747ef?w=300&h=300&fit=crop", alt: "Landschaft" },
  { src: "https://images.unsplash.com/photo-1596464716127-f2a82984de30?w=300&h=300&fit=crop", alt: "Familie Natur" },
];
---

<section class="section-padding bg-white" aria-labelledby="instagram-heading">
  <div class="container mx-auto text-center">
    <h2 id="instagram-heading" class="text-3xl font-extrabold mb-2">{title}</h2>
    <p class="text-anthracite-light mb-8">
      Teile deine Erlebnisse mit
      <a
        href={`https://www.instagram.com/${username}/`}
        target="_blank"
        rel="noopener noreferrer"
        class="text-ith-blue font-semibold"
      >
        @{username}
      </a>
      und dem Hashtag <span class="font-semibold text-ith-blue">#ithregion</span>
    </p>

    <!-- Photo Grid -->
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-2 mb-8">
      {placeholderImages.map((img) => (
        <a
          href={`https://www.instagram.com/${username}/`}
          target="_blank"
          rel="noopener noreferrer"
          class="group relative aspect-square overflow-hidden rounded-lg no-underline"
        >
          <img
            src={img.src}
            alt={img.alt}
            class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
            loading="lazy"
            width="300"
            height="300"
            decoding="async"
          />
          <div class="absolute inset-0 bg-ith-blue-dark/0 group-hover:bg-ith-blue-dark/40 transition-colors flex items-center justify-center">
            <svg class="w-8 h-8 text-white opacity-0 group-hover:opacity-100 transition-opacity" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" />
            </svg>
          </div>
        </a>
      ))}
    </div>

    <a
      href={`https://www.instagram.com/${username}/`}
      target="_blank"
      rel="noopener noreferrer"
      class="btn-primary"
    >
      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" />
      </svg>
      @{username} auf Instagram folgen
    </a>
  </div>
</section>
