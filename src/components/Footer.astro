---
const currentYear = new Date().getFullYear();
---

<footer class="bg-ith-blue-dark text-white" role="contentinfo">
  <div class="container mx-auto px-4 lg:px-6 py-16">
    <h2 class="sr-only">Footer</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
      <!-- Brand -->
      <div>
        <a href="/" class="flex items-center gap-3 no-underline mb-4">
          <img
            src="/images/logo-ith-region.svg"
            alt="Ith-Region – Zur Startseite"
            class="h-10 w-auto brightness-0 invert"
            width="200"
            height="60"
          />
          <span class="text-lg font-bold text-white">Ith-Region</span>
        </a>
        <p class="text-blue-100 text-sm leading-relaxed">
          Jeder Weg ist dein Erlebnis. Entdecke die Natur, Kultur und
          Gastfreundschaft der Ith-Region im Weserbergland.
        </p>
      </div>

      <!-- Erleben -->
      <div>
        <h3 class="text-white text-base font-semibold mb-4">Erleben</h3>
        <ul class="space-y-1">
          <li>
            <a href="/erleben/wandern/" class="text-blue-100 hover:text-white text-sm no-underline transition-colors inline-block py-1 min-h-[44px] flex items-center">Wandern</a>
          </li>
          <li>
            <a href="/erleben/radfahren/" class="text-blue-100 hover:text-white text-sm no-underline transition-colors inline-block py-1 min-h-[44px] flex items-center">Radfahren</a>
          </li>
          <li>
            <a href="/erleben/klettern/" class="text-blue-100 hover:text-white text-sm no-underline transition-colors inline-block py-1 min-h-[44px] flex items-center">Klettern</a>
          </li>
          <li>
            <a href="/erleben/natur/" class="text-blue-100 hover:text-white text-sm no-underline transition-colors inline-block py-1 min-h-[44px] flex items-center">Natur & Foto-Spots</a>
          </li>
          <li>
            <a href="/erleben/kultur/" class="text-blue-100 hover:text-white text-sm no-underline transition-colors inline-block py-1 min-h-[44px] flex items-center">Kultur & Geschichte</a>
          </li>
          <li>
            <a href="/erleben/familien/" class="text-blue-100 hover:text-white text-sm no-underline transition-colors inline-block py-1 min-h-[44px] flex items-center">Familien</a>
          </li>
        </ul>
      </div>

      <!-- Planen -->
      <div>
        <h3 class="text-white text-base font-semibold mb-4">Besuch planen</h3>
        <ul class="space-y-1">
          <li>
            <a href="/planen/unterkuenfte/" class="text-blue-100 hover:text-white text-sm no-underline transition-colors inline-block py-1 min-h-[44px] flex items-center">Unterkünfte</a>
          </li>
          <li>
            <a href="/planen/gastronomie/" class="text-blue-100 hover:text-white text-sm no-underline transition-colors inline-block py-1 min-h-[44px] flex items-center">Gastronomie</a>
          </li>
          <li>
            <a href="/planen/anreise/" class="text-blue-100 hover:text-white text-sm no-underline transition-colors inline-block py-1 min-h-[44px] flex items-center">Anreise & Parken</a>
          </li>
          <li>
            <a href="/planen/barrierefrei/" class="text-blue-100 hover:text-white text-sm no-underline transition-colors inline-block py-1 min-h-[44px] flex items-center">Barrierefreie Angebote</a>
          </li>
          <li>
            <a href="/veranstaltungen/" class="text-blue-100 hover:text-white text-sm no-underline transition-colors inline-block py-1 min-h-[44px] flex items-center">Veranstaltungen</a>
          </li>
        </ul>
      </div>

      <!-- Kontakt -->
      <div>
        <h3 class="text-white text-base font-semibold mb-4">Kontakt</h3>
        <address class="text-blue-100 text-sm not-italic space-y-2">
          <p>
            Flecken Salzhemmendorf<br />
            Hauptstraße 4<br />
            31020 Salzhemmendorf
          </p>
          <p>
            <a href="tel:+4951535008100" class="text-blue-100 hover:text-white no-underline transition-colors">Tel: 05153 5008-100</a>
          </p>
          <p>
            <a href="mailto:tourismus@salzhemmendorf.de" class="text-blue-100 hover:text-white no-underline transition-colors">tourismus@salzhemmendorf.de</a>
          </p>
        </address>
        <div class="flex gap-4 mt-4">
          <a
            href="https://www.instagram.com/ithregion/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-blue-100 hover:text-white transition-colors p-2 -m-2 min-w-[44px] min-h-[44px] flex items-center justify-center"
            aria-label="Ith-Region auf Instagram"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" />
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="border-t border-blue-800 mt-12 pt-8 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-blue-100 text-sm">
        &copy; {currentYear} Ith-Region &ndash; Flecken Salzhemmendorf & Coppenbrügge
      </p>
      <nav class="flex gap-6" aria-label="Rechtliches">
        <a href="/impressum/" class="text-blue-100 hover:text-white text-sm no-underline transition-colors py-2 min-h-[44px] inline-flex items-center">Impressum</a>
        <a href="/datenschutz/" class="text-blue-100 hover:text-white text-sm no-underline transition-colors py-2 min-h-[44px] inline-flex items-center">Datenschutz</a>
        <a href="/kontakt/" class="text-blue-100 hover:text-white text-sm no-underline transition-colors py-2 min-h-[44px] inline-flex items-center">Kontakt</a>
      </nav>
    </div>
  </div>
</footer>
