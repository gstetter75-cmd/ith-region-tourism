---
interface Props {
  title: string;
  subtitle?: string;
  imageSrc: string;
  imageAlt: string;
  ctaText?: string;
  ctaHref?: string;
  ctaSecondaryText?: string;
  ctaSecondaryHref?: string;
  overlay?: "light" | "medium" | "dark";
  size?: "full" | "large" | "medium";
}

const {
  title,
  subtitle,
  imageSrc,
  imageAlt,
  ctaText,
  ctaHref,
  ctaSecondaryText,
  ctaSecondaryHref,
  overlay = "medium",
  size = "large",
} = Astro.props;

const overlayClasses = {
  light: "bg-black/20",
  medium: "bg-black/40",
  dark: "bg-black/60",
};

const sizeClasses = {
  full: "min-h-screen",
  large: "min-h-[70vh]",
  medium: "min-h-[50vh]",
};
---

<section class={`relative ${sizeClasses[size]} flex items-center justify-center overflow-hidden`}>
  <!-- Background Image -->
  <img
    src={imageSrc}
    alt={imageAlt}
    class="absolute inset-0 w-full h-full object-cover"
    loading="eager"
  />

  <!-- Overlay -->
  <div class={`absolute inset-0 ${overlayClasses[overlay]}`}></div>

  <!-- Content -->
  <div class="relative z-10 text-center text-white px-4 max-w-4xl mx-auto">
    <h1
      class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white leading-tight mb-6 drop-shadow-lg"
    >
      {title}
    </h1>
    {
      subtitle && (
        <p class="text-lg sm:text-xl lg:text-2xl text-white/90 mb-8 max-w-2xl mx-auto drop-shadow">
          {subtitle}
        </p>
      )
    }
    {
      (ctaText || ctaSecondaryText) && (
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          {ctaText && ctaHref && (
            <a
              href={ctaHref}
              class="btn-primary bg-white text-ith-blue-dark hover:bg-sand hover:text-ith-blue-dark text-base"
            >
              {ctaText}
            </a>
          )}
          {ctaSecondaryText && ctaSecondaryHref && (
            <a
              href={ctaSecondaryHref}
              class="btn-secondary border-white text-white hover:bg-white hover:text-ith-blue-dark text-base"
            >
              {ctaSecondaryText}
            </a>
          )}
        </div>
      )
    }
  </div>

  <!-- Scroll Indicator -->
  {
    size === "full" && (
      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
        <svg
          class="w-6 h-6 text-white/70"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M19 14l-7 7m0 0l-7-7m7 7V3"
          />
        </svg>
      </div>
    )
  }
</section>
