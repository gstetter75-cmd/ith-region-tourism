---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import CookieBanner from "../components/CookieBanner.astro";
import ScrollToTop from "../components/ScrollToTop.astro";
import { getLangFromUrl, getLocalizedPath } from "../i18n/utils";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const lang = getLangFromUrl(Astro.url);
const isEnglish = lang === "en";

const {
  title,
  description = isEnglish
    ? "Discover the Ith-Region: Hiking, cycling, climbing and nature in the Weserbergland. Salzhemmendorf & Coppenbrügge – Every Path is Your Adventure."
    : "Die Ith-Region erleben: Wandern, Radfahren, Klettern und Natur im Weserbergland. Salzhemmendorf & Coppenbrügge - Jeder Weg ist dein Erlebnis.",
  ogImage = "/images/og-default.jpg",
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const homeTitles = { de: "Startseite", en: "Home" };
const fullTitle = title === homeTitles[lang]
  ? `Ith-Region | ${isEnglish ? "Every Path is Your Adventure" : "Jeder Weg ist dein Erlebnis"}`
  : `${title} | Ith-Region`;

const ogLocale = isEnglish ? "en_GB" : "de_DE";
const alternateLang = isEnglish ? "de" : "en";
const alternatePath = getLocalizedPath(Astro.url.pathname, alternateLang as "de" | "en");
const alternateUrl = new URL(alternatePath, Astro.site);
const skipText = isEnglish ? "Skip to main content" : "Zum Hauptinhalt springen";
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0174c3" />

    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang={alternateLang} href={alternateUrl} />
    <link rel="alternate" hreflang={lang} href={canonicalUrl} />
    <link rel="alternate" hreflang="x-default" href={new URL(getLocalizedPath(Astro.url.pathname, "de"), Astro.site)} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/icons/icon-192.png" />
    <link rel="manifest" href="/manifest.json" />
    <!-- Preconnect for external images -->
    <link rel="preconnect" href="https://images.unsplash.com" />
    <!-- Local fonts (DSGVO-konform, no external requests) -->
    <link rel="preload" href="/fonts/inter-latin.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={ogLocale} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

    <!-- JSON-LD -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "TouristDestination",
        name: "Ith-Region",
        description: description,
        url: Astro.site?.toString(),
        touristType: isEnglish
          ? ["Active tourists", "Families", "Short-break travelers", "Culture enthusiasts"]
          : ["Aktivtouristen", "Familien", "Kurzurlauber", "Kulturinteressierte"],
        containedInPlace: {
          "@type": "AdministrativeArea",
          name: "Weserbergland, Lower Saxony, Germany",
        },
      })}
    />

    <title>{fullTitle}</title>
  </head>
  <body class="min-h-screen flex flex-col bg-white">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[200] focus:bg-ith-blue focus:text-white focus:px-4 focus:py-2 focus:rounded-lg">
      {skipText}
    </a>
    <Header />
    <main id="main-content" class="flex-1">
      <slot />
    </main>
    <Footer />
    <CookieBanner />
    <ScrollToTop />
    <script>
      if ("serviceWorker" in navigator) {
        navigator.serviceWorker.register("/sw.js").catch(() => {});
      }
    </script>
  </body>
</html>
