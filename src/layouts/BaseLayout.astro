---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import CookieBanner from "../components/CookieBanner.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = "Die Ith-Region erleben: Wandern, Radfahren, Klettern und Natur im Weserbergland. Salzhemmendorf & Coppenbrügge - Jeder Weg ist dein Erlebnis.",
  ogImage = "/images/og-default.jpg",
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const fullTitle = title === "Startseite" ? "Ith-Region | Jeder Weg ist dein Erlebnis" : `${title} | Ith-Region`;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0174c3" />

    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="de_DE" />

    <!-- JSON-LD -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "TouristDestination",
        name: "Ith-Region",
        description: description,
        url: Astro.site?.toString(),
        touristType: [
          "Aktivtouristen",
          "Familien",
          "Kurzurlauber",
          "Kulturinteressierte",
        ],
        containedInPlace: {
          "@type": "AdministrativeArea",
          name: "Weserbergland, Niedersachsen",
        },
      })}
    />

    <title>{fullTitle}</title>
  </head>
  <body class="min-h-screen flex flex-col bg-white">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <CookieBanner />
  </body>
</html>
